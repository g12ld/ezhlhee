{
  "hosting": [
    {
      "target": "webapp_site",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "*.py",
        "functions/**",
        "firestore.*",
        "package*.json",
        "*.txt",
        "README.md",
        "للل"
      ],
      "cleanUrls": false,
      "trailingSlash": false,
      "errorPage": "404.html",
      "redirects": [
        { "source": "/index.html", "destination": "/", "type": 301 },
        { "source": "/data-analysis.html", "destination": "/", "type": 301 },
        { "source": "/articles/guide-design-store.html", "destination": "/salla-store-design.html", "type": 301 },
        { "source": "/articles/service1-article1.html", "destination": "/", "type": 301 },
        { "source": "/articles/service1-article4.html", "destination": "/", "type": 301 },
        { "source": "/articles/service2-article5.html", "destination": "/", "type": 301 },
        { "source": "/articles/service3-article4.html", "destination": "/", "type": 301 },
