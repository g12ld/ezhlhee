        { "source": "/articles/service10-article8.html", "destination": "/", "type": 301 }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=3600" },
            { "key": "X-Content-Type-Options", "value": "nosniff" }
          ]
        },
        {
          "source": "/articles/**",
          "headers": [
            { "key": "X-Robots-Tag", "value": "index, follow" }
          ]
        }
      ]
    },
    {
      "target": "firebaseapp_site",
      "public": ".",
      "ignore": [
